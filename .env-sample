# =============================================================================
# .env — Local TTS Web Application secrets & configuration
# Do NOT commit this file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/tts_db"

# ---------------------------------------------------------------------------
# Model paths
# ---------------------------------------------------------------------------
FISH_SPEECH_CKPT="/models/fish-speech-1.5"
XTTS_MODEL_ID="tts_models/multilingual/multi-dataset/xtts_v2"
XTTS_SPEAKER_WAV="/app/static/reference_speaker.wav"

# ---------------------------------------------------------------------------
# Audio output
# ---------------------------------------------------------------------------
AUDIO_OUTPUT_DIR="/app/static/audio"

# ---------------------------------------------------------------------------
# Inference
# ---------------------------------------------------------------------------
DEVICE="cuda"
LAZY_XTTS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL="INFO"
